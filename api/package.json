{
  "name": "@workspace/nordsocks-selfhosted-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export PORT=8083 NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2",
    "dockerode": "^4.0.10",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "ssh2": "^1.17.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
